# Environment variables for College Admission Counselling Environment
# Copy this file to .env and fill in your values
# NEVER commit the actual .env file to git — only commit .env.example

# ── Groq API (FREE — used for baseline testing) ──────────────
# Get free key at: console.groq.com
# Uses Llama 3 via Groq (same model as Meta's Llama, much faster, free tier)
GROQ_API_KEY=your_groq_api_key_here

# ── OpenAI API (uncomment when ready to use) ─────────────────
# Get key at: platform.openai.com
# OPENAI_API_KEY=your_openai_api_key_here

# ── Hugging Face (for pushing to HF Spaces) ──────────────────
# Get token at: huggingface.co/settings/tokens (needs Write permission)
HF_TOKEN=your_hf_token_here

# ── HF Space URL (update after deploying) ────────────────────
HF_SPACE_URL=https://Knight09-college-admission-env.hf.space
